# =============================================================================
# Vardo — Environment Variables
# =============================================================================
# These are infrastructure connection strings and build-time settings only.
# Application configuration (email, backups, GitHub, feature flags) is managed
# via vardo.yml / vardo.secrets.yml or the admin UI.
#
# Copy to .env and fill in values. install.sh generates this automatically.
# =============================================================================

# ---------------------
# Environment
# ---------------------
# Omit COMPOSE_PROFILES for dev (app container skipped, use pnpm dev).
# Set COMPOSE_PROFILES=production for full stack (install.sh does this).
# COMPOSE_PROFILES=production
TRAEFIK_LOG_LEVEL=INFO

# ---------------------
# Traefik
# ---------------------
# Docker network filter for Traefik container discovery.
#   vardo-network  = default — only discover Vardo-managed containers (recommended)
#   (empty string) = no filter — discover all containers with traefik.enable=true
# Change via Admin → Settings → Traefik, then restart the Traefik container.
TRAEFIK_DOCKER_NETWORK=vardo-network

# ---------------------
# Database & Cache
# ---------------------
DATABASE_URL=postgresql://host:host@localhost:7100/host
REDIS_URL=redis://localhost:7200

# ---------------------
# Auth
# ---------------------
BETTER_AUTH_SECRET=vardo-dev-secret-change-in-production
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------
# Encryption
# ---------------------
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=

# ---------------------
# Instance Identity
# ---------------------
VARDO_INSTANCE_ID=
VARDO_DOMAIN=localhost
# VARDO_PROJECTS_DIR=     # Default: ./.host/projects (dev), /var/lib/host/projects (prod)

# ---------------------
# TLS (production only)
# ---------------------
# ACME_EMAIL=you@example.com
# ZEROSSL_EAB_KID=
# ZEROSSL_EAB_HMAC=
# CF_DNS_API_TOKEN=    # Cloudflare API token for DNS-01 challenge (Zone:DNS:Edit permission)

# ---------------------
# Self-Management (optional)
# ---------------------
# Enable via Admin → Settings → Features → selfManagement.
# VARDO_DIR must point to the directory where Vardo itself is deployed so
# the startup registration can read docker-compose.yml and resolve git info.
# VARDO_DIR=/opt/vardo
#
# Preview containers reuse the running vardo-postgres and vardo-redis services
# by default. Set PREVIEW_DATABASE_URL (and optionally PREVIEW_REDIS_URL) to
# point previews at an isolated database instead. Strongly recommended when
# the Vardo repo is accessible to external contributors.
# PREVIEW_DATABASE_URL=postgresql://preview_user:pass@localhost:7100/preview
# PREVIEW_REDIS_URL=redis://localhost:7200/1

# ---------------------
# Analytics (optional)
# ---------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_SRC=
